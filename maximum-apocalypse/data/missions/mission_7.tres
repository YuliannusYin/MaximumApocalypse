mission_name = "侦查外星人地区"
difficulty = "困难"
required_van_fuel = 4
monster_type = 0
description = "我们的军事实力不及外星人。但是，如果他们认为我们会在他们摧毁我们的文明之后坐以待毙，那么他们就大错特错了。我们要侦察一下这个地区，这样我们就知道发起攻击的最佳地点。"
objective_text = "目标：展示所有地图块，然后带着足够多的燃料返回面包车上逃跑。"
