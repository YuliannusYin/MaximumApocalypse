[ext_resource type="Script" path="res://MissionData.gd" id="1_mission"]

[resource]
script = ExtResource("1_mission")
id = "mission_9"
mission_name = "人类反击"
difficulty = "困难"
required_van_fuel = 0
description = "根据你找到的情报，我们绘制出了控制他们的机械和无人机的外星神经网络图。我们团队的科学家们写了一个让他们瘫痪的病毒。我们击毁了一艘外星飞船，现在需要到那里上传病毒。"
objective_text = "目标：摧毁2个外星发射器，然后把科学家带到现场去上传病毒。"
starting_tile_id = "van"
initial_setup_rule = "设置：把1个目标标记和3个怪物标记各放到2个地图块上。这代表被守卫的外星发射器。你可以花费1个行动来摧毁1个发射器。首领：把2张首领卡洗入怪物牌库。"
