# ============================================
# Apocrypha - Trae AI Agent 忽略文件配置
# 说明：AI Agent 在读写文件时应忽略以下内容
# 格式：每行一个 glob 模式，# 开头为注释
# ============================================

# ---------- Godot 引擎缓存 ----------
.godot/
*.tmp
*.temp

# ---------- 操作系统文件 ----------
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
desktop.ini
$RECYCLE.BIN/
*.lnk
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
# Linux
*~
.directory
.Trash-*

# ---------- 编辑器 / IDE 文件 ----------
.vscode/
.idea/
*.swp
*.swo
*.swn
*.bak
*.orig

# ---------- 构建 / 导出产物 ----------
export/
builds/
build/
dist/
bin/
*.exe
*.apk
*.aab
*.app
*.x86_64
*.pck
*.zip
*.tar.gz

# ---------- 日志与临时文件 ----------
*.log
logs/
tmp/
temp/

# ---------- 依赖与第三方库（如有） ----------
addons/*/node_modules/
