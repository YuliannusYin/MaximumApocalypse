# ============================================
# Maximum Apocalypse - Git 忽略文件配置（根目录通用规则）
# ============================================

# ---------- 操作系统文件 ----------
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
desktop.ini
$RECYCLE.BIN/
*.lnk
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
# Linux
*~
.directory
.Trash-*

# ---------- 编辑器 / IDE 文件 ----------
.idea/
.vscode/
*.swp
*.swo
*.swn
*.bak
*.orig
.vscode/settings.json
.trae/
.godot/

# ---------- 通用构建 / 导出产物 ----------
build/
dist/
bin/
*.zip
*.tar.gz
*.tar.bz2
*.7z
*.rar

# ---------- 日志与临时文件 ----------
*.log
logs/
tmp/
temp/
RecycleBin/

# ---------- 依赖与第三方库 ----------
node_modules/
addons/*/node_modules/

# ---------- 敏感信息（切勿提交） ----------
.env
.env.local
.env.*.local
*.secret
credentials.json
*.pem
*.key
